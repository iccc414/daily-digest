# ============================================================
# 環境変数サンプル
# このファイルをコピーして .env を作成し、実際の値を入力してください
# .env は .gitignore に追加済みで、絶対にコミットしないこと
# ============================================================

# Anthropic Claude API キー（https://console.anthropic.com）
CLAUDE_API_KEY=sk-ant-api03-...

# Google サービスアカウント JSON を base64 エンコードした文字列
# 作成方法: base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_KEY=eyJ0eXBlIjoic2Vydmlj...

# Google Drive のルートフォルダ ID
# フォルダを開いて URL から取得: https://drive.google.com/drive/folders/THIS_IS_THE_ID
DRIVE_FOLDER_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ

# ログ用 Google Sheet ID（省略可能 - なければ Sheet ログをスキップ）
# スプレッドシートを開いて URL から取得: https://docs.google.com/spreadsheets/d/THIS_IS_THE_ID/edit
LOG_SHEET_ID=1aBcDeFgHiJkLmNoPqRsTuVwXyZ
